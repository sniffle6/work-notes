{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://work-notes.local/schemas/parse-note.schema.json",
  "title": "Work Notes Parse Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "title",
    "cleanedText",
    "summary",
    "tags",
    "actionItems"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "cleanedText": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "kind",
          "confidence"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "person",
              "project",
              "topic",
              "urgency",
              "category",
              "custom"
            ]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "actionItems": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "text",
          "owner",
          "dueDate",
          "confidence",
          "requiresReview"
        ],
        "properties": {
          "text": {
            "type": "string",
            "minLength": 1
          },
          "owner": {
            "type": [
              "string",
              "null"
            ]
          },
          "dueDate": {
            "type": [
              "string",
              "null"
            ]
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "requiresReview": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
