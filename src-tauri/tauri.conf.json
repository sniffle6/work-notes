{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Work Notes",
  "version": "0.1.5",
  "identifier": "com.aweber.worknotes",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Work Notes",
        "width": 1100,
        "height": 720
      },
      {
        "label": "quick-capture",
        "title": "Quick Capture",
        "url": "index.html",
        "width": 560,
        "height": 260,
        "resizable": false,
        "decorations": false,
        "skipTaskbar": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/sniffle6/work-notes/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcyNjU5MjIzNDM5RjE1RTUKUldUbEZaOURJNUpsY3R4NVZWNldYOG82Nk5qQmowMm5JQ2tEYUxLdS9QeVZNL1d1ZTdQMC9hSEYK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
